# Supabase (server-side only — service role key never reaches the client bundle)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AWS credentials for invoking the Lambdas from the "Run Lambdas" menu.
# Uses the standard AWS SDK credential chain; region defaults to us-east-1.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
